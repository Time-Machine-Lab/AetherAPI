    {
      "apiCode": "wuyin-gpt-image-2",
      "categoryCode": "image",
      "assetName": "Wuyin GPT Image 2.0",
      "assetType": "AI_API",
      "requestMethod": "POST",
      "upstreamUrl": "http://api.wuyinkeji.com/api/async/image_gpt",
      "authScheme": "QUERY_TOKEN",
      "authConfig": "key=${env:WUYIN_MEDIA_API_KEY}",
      "requestExample": "{\"prompt\":\"a product photo of a red backpack, studio lighting\",\"size\":\"1:1\",\"urls\":[\"http://example.com/input.png\"]}",
      "responseExample": "{\"data\":{\"id\":\"wuyin-gpt-image-task-001\",\"status\":\"0\"}}",
      "requestJsonSchema": {
        "type": "object",
        "required": ["prompt"],
        "properties": {
          "prompt": {
            "type": "string"
          },
          "size": {
            "type": "string"
          },
          "urls": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "responseJsonSchema": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "status": {
                "type": "string"
              }
            }
          }
        }
      },
      "asyncTaskConfig": {
        "enabled": true,
        "queryMethod": "GET",
        "queryUrlTemplate": "http://api.wuyinkeji.com/api/async/detail?id={taskId}",
        "authMode": "SAME_AS_SUBMIT",
        "statusPath": "$.data.status",
        "resultPath": "$.data.result",
        "errorPath": "$.message"
      },
      "aiProfile": {
        "provider": "wuyin",
        "model": "gpt-image-2",
        "streamingSupported": false,
        "capabilityTags": ["图像生成", "图生图", "异步任务"]
      }
    },
