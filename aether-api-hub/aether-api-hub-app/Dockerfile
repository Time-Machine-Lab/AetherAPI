FROM eclipse-temurin:17-jre

# 设置时区为上海
RUN ln -sf /usr/share/zoneinfo/Asia/Shanghai /etc/localtime && echo 'Asia/Shanghai' > /etc/timezone
ENV TZ=Asia/Shanghai

# 构建上下文内需仅含一个可执行 fat JAR（与 CI 中 cp ./target/*.jar 一致）
COPY *.jar /aether-api.jar

ARG SERVER_PORT
ARG ACTIVE
ARG UNIQUE_ID
ARG JASYPT_PASSWORD

ARG MYSQL_ADDR
ARG MYSQL_USERNAME
ARG MYSQL_PASSWORD

ARG REDIS_ADDR
ARG REDIS_PORT
ARG REDIS_PWD

ARG NACOS_SERVER_ADDR
ARG NACOS_SERVER_USER
ARG NACOS_SERVER_PASSWORD

ARG MQ_ADDR
ARG MQ_PORT
ARG MQ_USERNAME
ARG MQ_PWD

ENV SERVER_PORT=${SERVER_PORT}
ENV UNIQUE_ID=${UNIQUE_ID}
ENV JASYPT_PASSWORD=${JASYPT_PASSWORD}
ENV ACTIVE=${ACTIVE}

EXPOSE ${SERVER_PORT}

ENTRYPOINT ["java","-jar","/aether-api.jar"]